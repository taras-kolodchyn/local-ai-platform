# Generated secrets are written to .env by `make bootstrap`.
LITELLM_MASTER_KEY=GENERATE_ME
POSTGRES_PASSWORD=GENERATE_ME
REDIS_PASSWORD=GENERATE_ME
GRAFANA_ADMIN_PASSWORD=GENERATE_ME
MCP_POSTGRES_PASSWORD=GENERATE_ME

# Pinned model artifacts. Clients use aliases, not these names.
QWEN_MODEL=ai/qwen3-coder:30B-A3B-UD-Q4_K_XL
EMBEDDING_MODEL=ai/qwen3-embedding:0.6B-F16
QWEN_CONTEXT_SIZE=65536
EMBEDDING_DIMENSIONS=1024

# DMR is reachable from containers through Docker Desktop's host bridge.
INFERENCE_BASE_URL=http://host.docker.internal:12434/engines/v1
INFERENCE_API_KEY=local-dmr-no-auth

# Gateway and retrieval policy.
LITELLM_CACHE_TTL=300
LITELLM_CACHE_NAMESPACE=local-ai-platform
RETRIEVAL_DEFAULT_LIMIT=6
RETRIEVAL_MAX_LIMIT=12
RETRIEVAL_MAX_CONTEXT_CHARS=24000
LOG_LEVEL=INFO
MCP_REPO_PATH=.
