{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum by (route) (rate(litellm_proxy_total_requests_metric_total[5m]))", "legendFormat": "{{route}}", "refId": "A"}],
      "title": "Gateway request rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum(rate(litellm_request_total_latency_metric_sum[5m])) / clamp_min(sum(rate(litellm_request_total_latency_metric_count[5m])), 1e-9)", "legendFormat": "mean end-to-end", "refId": "A"}, {"expr": "sum(rate(litellm_llm_api_latency_metric_sum[5m])) / clamp_min(sum(rate(litellm_llm_api_latency_metric_count[5m])), 1e-9)", "legendFormat": "mean inference", "refId": "B"}],
      "title": "Gateway and inference latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [{"expr": "sum by (exception_class) (rate(litellm_proxy_failed_requests_metric_total[5m]))", "legendFormat": "{{exception_class}}", "refId": "A"}],
      "title": "Gateway errors",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "targets": [{"expr": "sum(rate(litellm_input_tokens_metric_total[5m]))", "legendFormat": "input tokens/s", "refId": "A"}, {"expr": "sum(rate(litellm_output_tokens_metric_total[5m]))", "legendFormat": "output tokens/s", "refId": "B"}],
      "title": "Token throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "targets": [{"expr": "rate(redis_keyspace_hits_total[5m]) / clamp_min(rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]), 1e-9)", "legendFormat": "Redis key hit ratio", "refId": "A"}],
      "title": "Redis cache hit ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "targets": [{"expr": "increase(litellm_cached_tokens_metric_total[1h])", "legendFormat": "response-cache tokens", "refId": "A"}],
      "title": "LiteLLM response-cache tokens (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "id": 7,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(local_ai_retrieval_duration_seconds_bucket[5m])))", "legendFormat": "retrieval p95", "refId": "A"}, {"expr": "histogram_quantile(0.95, sum by (le) (rate(local_ai_vector_search_duration_seconds_bucket[5m])))", "legendFormat": "pgvector p95", "refId": "B"}],
      "title": "Retrieval latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "id": 8,
      "targets": [{"expr": "sum by (tool, status) (rate(local_ai_mcp_tool_calls_total[5m]))", "legendFormat": "{{tool}} {{status}}", "refId": "A"}],
      "title": "MCP tool calls",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "id": 9,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (tool, le) (rate(local_ai_mcp_tool_duration_seconds_bucket[5m])))", "legendFormat": "{{tool}}", "refId": "A"}],
      "title": "MCP tool duration p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "id": 10,
      "targets": [{"expr": "local_ai_indexed_files", "legendFormat": "files", "refId": "A"}, {"expr": "local_ai_indexed_chunks", "legendFormat": "chunks", "refId": "B"}, {"expr": "local_ai_indexed_snapshots", "legendFormat": "snapshots", "refId": "C"}],
      "title": "Indexed knowledge base",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "id": 11,
      "targets": [{"expr": "local_ai_last_ingestion_files", "legendFormat": "files", "refId": "A"}, {"expr": "sum by (status) (local_ai_last_ingestion_chunks)", "legendFormat": "chunks {{status}}", "refId": "B"}, {"expr": "local_ai_last_ingestion_skipped_sensitive", "legendFormat": "sensitive skipped", "refId": "C"}],
      "title": "Last ingestion",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "id": 12,
      "targets": [{"expr": "pg_up", "legendFormat": "Postgres", "refId": "A"}, {"expr": "redis_up", "legendFormat": "Redis", "refId": "B"}, {"expr": "min(up{job=~\"litellm|retrieval|mcp-tools\"})", "legendFormat": "app scrapes", "refId": "C"}],
      "title": "Service health",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 32},
      "id": 13,
      "options": {"showTime": true, "wrapLogMessage": true},
      "targets": [{"expr": "{job=\"local-ai-platform\"}", "refId": "A"}],
      "title": "Metadata-only platform logs",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 42,
  "tags": ["local-ai", "apple-silicon"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Local AI Platform",
  "uid": "local-ai-platform",
  "version": 2
}
